@model List<QuanLyChiTieuCaNhan.Models.Wallet>
@{
    ViewBag.Title = "Ví tiền";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4><i class="fas fa-wallet"></i> Ví tiền</h4>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="fas fa-plus"></i> Thêm ví
    </a>
</div>

<div class="row">
    @foreach (var wallet in Model)
    {
        var typeName = wallet.WalletType == 1 ? "Tiền mặt" : (wallet.WalletType == 2 ? "Ngân hàng" : "Ví điện tử");
        var typeIcon = wallet.WalletType == 1 ? "fa-money-bill-wave" : (wallet.WalletType == 2 ? "fa-university" : "fa-mobile-alt");
        var borderClass = wallet.IsDefault ? "border-primary" : "";

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm @borderClass">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <h5 class="card-title">
                            <i class="fas @typeIcon text-primary"></i> @wallet.Name
                        </h5>
                        @if (wallet.IsDefault)
                        {
                            <span class="badge badge-primary">Mặc định</span>
                        }
                    </div>
                    <p class="text-muted small mb-1">@typeName</p>
                    <h4 class="@(wallet.Balance >= 0 ? "text-success" : "text-danger")">
                        @wallet.Balance.ToString("N0") VND
                    </h4>
                </div>
                <div class="card-footer bg-white">
                    <a href="@Url.Action("Edit", new { id = wallet.WalletId })" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-edit"></i> Sửa
                    </a>
                    @if (!wallet.IsDefault)
                    {
                        using (Html.BeginForm("Delete", "Wallet", new { id = wallet.WalletId }, FormMethod.Post, new { @class = "d-inline", onclick = "return confirm('Xóa ví này?')" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-trash"></i> Xóa
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted">Chưa có ví tiền nào</p>
    </div>
}
