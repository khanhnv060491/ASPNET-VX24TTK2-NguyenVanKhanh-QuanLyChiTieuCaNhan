@model QuanLyChiTieuCaNhan.Models.ViewModels.ReportViewModel
@{
    ViewBag.Title = "Báo cáo";
}

<h4 class="mb-3"><i class="fas fa-file-alt"></i> Báo cáo</h4>

<!-- Bộ lọc -->
<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        @using (Html.BeginForm("Index", "Report", FormMethod.Get, new { @class = "form-inline" }))
        {
            <div class="form-group mr-2">
                <label class="mr-2">Từ ngày:</label>
                <input type="date" name="fromDate" class="form-control form-control-sm" value="@(Model.FromDate.HasValue ? Model.FromDate.Value.ToString("yyyy-MM-dd") : "")" />
            </div>
            <div class="form-group mr-2">
                <label class="mr-2">Đến ngày:</label>
                <input type="date" name="toDate" class="form-control form-control-sm" value="@(Model.ToDate.HasValue ? Model.ToDate.Value.ToString("yyyy-MM-dd") : "")" />
            </div>
            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-search"></i> Xem báo cáo
            </button>
        }
    </div>
</div>

<!-- Tóm tắt -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-left-success shadow-sm">
            <div class="card-body text-center">
                <div class="text-success font-weight-bold small text-uppercase">Tổng thu</div>
                <div class="h5 font-weight-bold text-success">@Model.TotalIncome.ToString("N0") VND</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-left-danger shadow-sm">
            <div class="card-body text-center">
                <div class="text-danger font-weight-bold small text-uppercase">Tổng chi</div>
                <div class="h5 font-weight-bold text-danger">@Model.TotalExpense.ToString("N0") VND</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-left-info shadow-sm">
            <div class="card-body text-center">
                <div class="text-info font-weight-bold small text-uppercase">Số dư</div>
                <div class="h5 font-weight-bold @(Model.Balance >= 0 ? "text-success" : "text-danger")">
                    @Model.Balance.ToString("N0") VND
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bảng giao dịch -->
<div class="card shadow-sm">
    <div class="card-header bg-white font-weight-bold">
        Chi tiết giao dịch (@Model.Transactions.Count giao dịch)
    </div>
    <div class="card-body p-0">
        @if (Model.Transactions.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>Ngày</th>
                            <th>Loại</th>
                            <th>Danh mục</th>
                            <th>Ví</th>
                            <th>Ghi chú</th>
                            <th class="text-right">Số tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.Transactions)
                        {
                            var typeBadge = t.TransactionType == 1 ? "badge-success" : (t.TransactionType == 2 ? "badge-danger" : "badge-info");
                            var typeName = t.TransactionType == 1 ? "Thu" : (t.TransactionType == 2 ? "Chi" : "Chuyển");
                            var amountClass = t.TransactionType == 1 ? "text-success" : (t.TransactionType == 2 ? "text-danger" : "text-info");
                            var prefix = t.TransactionType == 1 ? "+" : (t.TransactionType == 2 ? "-" : "↔");

                            <tr>
                                <td>@t.TransactionDate.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge @typeBadge">@typeName</span></td>
                                <td>@(t.Category != null ? t.Category.Name : "N/A")</td>
                                <td>@(t.Wallet != null ? t.Wallet.Name : "N/A")</td>
                                <td><small class="text-muted">@(t.Description ?? "")</small></td>
                                <td class="text-right font-weight-bold @amountClass">@prefix@t.Amount.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted text-center py-5">Không có giao dịch trong khoảng thời gian này</p>
        }
    </div>
</div>
